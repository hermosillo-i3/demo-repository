  "scripts": {
    "dev": " nodemon index.js --ignore 'logs/*' --ignore 'database_migration/*' --ignore 'playground/*'",
    "test": " set \"NODE_ENV=test\" && jest --detectOpenHandles --runInBand",
    "debug": " SET \"NODE_ENV=development\" && node --inspect-brk index.js",
    "migration-db": " npx sequelize-cli db:migrate --env development",
    "migration-db-undo": " npx sequelize-cli db:migrate:undo",
    "migration-db-prod": "npx sequelize-cli db:migrate --env production",
    "migration-skeleton-db": "sequelize-cli db:migrate --migrations-path \"database_migration/skeleton\"",
    "generate-migration-file": "npx sequelize-cli migration:generate --name ",
    "generate-skeleton-file": "npx sequelize-cli migration:generate --migrations-path \"database_migration/skeleton\" --name "
  },
